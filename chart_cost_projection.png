ASSETS = "charts"

def hr(color=LINE, thickness=0.8, space_before=4, space_after=12):
    return HRFlowable(width="100%", thickness=thickness, color=color, spaceBefore=space_before, spaceAfter=space_after)

def bullets(items):
    return ListFlowable([ListItem(Paragraph(i, styles["BulletItem"]), bulletColor=TEAL) for i in items],
                         bulletType="bullet", start="circle", leftIndent=14, spaceBefore=2, spaceAfter=10)

def styled_table(data, col_widths=None, header_bg=INK, align_first_left=True, font_size=9):
    def cell_style(is_header, is_first_col):
        align = TA_LEFT if (align_first_left and is_first_col and not is_header) else TA_CENTER
        if is_header:
            return ParagraphStyle(f"th_{font_size}", fontName="Helvetica-Bold", fontSize=font_size,
                                   leading=font_size+3.2, textColor=colors.white, alignment=TA_CENTER)
        return ParagraphStyle(f"tc_{font_size}_{align}_{is_first_col}", fontName="Helvetica", fontSize=font_size,
                               leading=font_size+3.4, textColor=INK, alignment=align)

    wrapped = []
    for r, row in enumerate(data):
        new_row = []
        for c, val in enumerate(row):
            text = str(val).replace("\n", "<br/>")
            new_row.append(Paragraph(text, cell_style(is_header=(r==0), is_first_col=(c==0))))
        wrapped.append(new_row)

    t = Table(wrapped, colWidths=col_widths, repeatRows=1)
    style = [
        ("BACKGROUND", (0,0), (-1,0), header_bg),
        ("VALIGN", (0,0), (-1,-1), "MIDDLE"),
        ("GRID", (0,0), (-1,-1), 0.6, LINE),
        ("ROWBACKGROUNDS", (0,1), (-1,-1), [colors.white, colors.HexColor("#F7F8F5")]),
        ("TOPPADDING", (0,0), (-1,-1), 7),
        ("BOTTOMPADDING", (0,0), (-1,-1), 7),
        ("LEFTPADDING", (0,0), (-1,-1), 8),
        ("RIGHTPADDING", (0,0), (-1,-1), 7),
    ]
    t.setStyle(TableStyle(style))
    return t

def kpi_row(items):
    """items: list of (label, value)"""
    table_data = [[Paragraph(val, styles["KPIVal"]) for _, val in items],
                  [Paragraph(label.upper(), styles["KPILabel"]) for label, _ in items]]
    t = Table(table_data, colWidths=[(6.6*inch)/len(items)]*len(items))
    t.setStyle(TableStyle([
        ("ALIGN", (0,0), (-1,-1), "CENTER"),
        ("VALIGN", (0,0), (-1,-1), "MIDDLE"),
        ("TOPPADDING", (0,0), (-1,0), 16),
        ("BOTTOMPADDING", (0,0), (-1,0), 2),
        ("TOPPADDING", (0,1), (-1,1), 2),
        ("BOTTOMPADDING", (0,1), (-1,1), 16),
        ("BOX", (0,0), (-1,-1), 0.8, LINE),
        ("INNERGRID", (0,0), (-1,-1), 0.5, LINE),
        ("BACKGROUND", (0,0), (-1,-1), colors.HexColor("#FAFAF7")),
    ]))
    return t

def footer(canvas, doc):
    canvas.saveState()
    canvas.setStrokeColor(LINE)
    canvas.line(0.75*inch, 0.65*inch, letter[0]-0.75*inch, 0.65*inch)
    canvas.setFont("Helvetica", 8)
    canvas.setFillColor(INK_SOFT)
    canvas.drawString(0.75*inch, 0.48*inch, "AI-Powered AP Invoice Processing Automation — Capstone Report")
    canvas.drawRightString(letter[0]-0.75*inch, 0.48*inch, f"Page {doc.page}")
    canvas.restoreState()


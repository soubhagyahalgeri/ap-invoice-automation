# ===================== 7. RISKS / LIMITATIONS =====================
story.append(Paragraph("7. Risks, Controls & Limitations", styles["H1"]))
story.append(bullets([
    "<b>Small sample size:</b> 100% extraction accuracy was measured on 13 invoices. Production-grade "
    "accuracy claims would require testing on hundreds of invoices across wider format, language, and "
    "image-quality variation.",
    "<b>Mock ERP posting:</b> the ledger write is simulated; no real ERP, GL system, or payment rail is integrated.",
    "<b>Single currency, single entity:</b> no multi-currency, multi-tax-jurisdiction, or intercompany logic.",
    "<b>No dedicated fraud controls:</b> e.g., no bank-detail-change monitoring or vendor-impersonation detection.",
    "<b>Live-demo dependency:</b> the prototype's extraction call relies on Claude.ai's built-in request "
    "proxy. A public, always-on version would require a dedicated API key behind a backend proxy.",
    "<b>Illustrative approval thresholds:</b> the $750 / $5,000 / 3% tolerance values are reasonable "
    "defaults, not tuned to any specific organization's risk appetite.",
]))
story.append(PageBreak())

